# -----------------------------------------------
# Masaar CRM — Environment Variables
# Copy to .env and fill in your values
# -----------------------------------------------

# Server
PORT=8080
APP_ENV=development

# PostgreSQL (pgvector enabled)
DATABASE_URL=postgres://masaar:masaar@localhost:5432/masaar?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — change JWT_SECRET to a long random string in production
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY_MIN=15
JWT_REFRESH_EXPIRY_DAYS=7

# WhatsApp Business API
WA_VERIFY_TOKEN=masaar-webhook-token
WA_API_VERSION=v19.0
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
